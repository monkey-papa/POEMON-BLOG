# ==================== 数据库配置 ====================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=myblog

# ==================== JWT配置（必须修改！）====================
# 生产环境务必设置一个足够复杂的随机字符串
# 可以使用: openssl rand -base64 32 生成
JWT_SECRET=your_jwt_secret_change_me

# ==================== 邮件配置 ====================
EMAIL_FROM=your_email@qq.com
EMAIL_PASSWORD=your_smtp_password
EMAIL_SMTP_HOST=smtp.qq.com
EMAIL_SMTP_PORT=465

# ==================== AI摘要服务配置（OpenAI兼容，默认DeepSeek）====================
# DeepSeek: https://platform.deepseek.com 注册获取 API Key
# 也可替换为其他 OpenAI 兼容服务（如 OpenAI、硅基流动等），只需修改 URL 和 MODEL
AI_API_KEY=your_ai_api_key
AI_API_URL=https://api.deepseek.com/v1
AI_MODEL=deepseek-chat

# ==================== 站点信息配置 ====================
SITE_NAME=My-Blog
SITE_URL=https://your-domain.com
BOSS_WECHAT=your_wechat_id
EMAIL_HEADER_IMAGE=https://your-domain.com/email-header.png

# ==================== 天气API配置（apihz.cn）====================
# 前往 https://www.apihz.cn 注册获取
WEATHER_API_ID=your_weather_api_id
WEATHER_API_KEY=your_weather_api_key

# ==================== CORS配置 ====================
# 生产环境允许的域名白名单，多个用逗号分隔
CORS_ALLOWED_ORIGINS=https://your-domain.com,http://your-domain.com

# ==================== 服务器配置 ====================
SERVER_PORT=8000
# development 或 production
ENVIRONMENT=development

# ==================== 默认值配置 ====================
# 删除分类/标签时，文章移动到的默认分类/标签ID
DEFAULT_SORT_ID=11
DEFAULT_LABEL_ID=23

# ==================== 验证配置（可选）====================
MAX_USERNAME_LENGTH=50
MAX_PASSWORD_LENGTH=128
MIN_PASSWORD_LENGTH=6
MAX_ARTICLE_TITLE_LENGTH=200
MAX_COMMENT_LENGTH=2000
MAX_TREEHOLE_LENGTH=500

# ==================== 日志配置 ====================
DB_LOG_SQL=false
